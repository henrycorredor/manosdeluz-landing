---
import { Image } from "astro:assets"
import HeroBackground from "../../assets/hero-standard.jpg"
import Logo from "../../assets/manos-de-luz-logo-white.svg"
import MailIcon from "../../assets/footer-icon-mail.svg"
import PhoneIcon from "../../assets/footer-icon-whatsapp.svg"
import SocialFB from "../../assets/social-facebook.svg"
import SocialIns from "../../assets/social-instagram.svg"
---

<section>
  <main class="hero-main" style={`background-image: url(${HeroBackground.src})`}>
    <div class="hero-content">
      <div class="left-column">
        <Image src={Logo} alt="Manos de Luz - Logo" />
      </div>
      <div class="right-column">
        <div class="row title">Products for Botanica & Spiritual Supplies</div>
        <div class="row email" style={`background-image: url(${MailIcon.src})`}>marketing@manosdeluz.net</div>
        <div class="row phone" style={`background-image: url(${PhoneIcon.src})`}>+1 (475) 280 1913</div>
        <div class="row social">
          <div class="social-icons">
            <Image src={SocialFB} alt="Facebook" />
            <Image src={SocialIns} alt="Instagram" />
          </div>
          mdeluz25
        </div>
      </div>
    </div>
  </main>
</section>

<style lang="less">
  .hero-main {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 98vh;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .hero-content {
    display: flex;
    gap: 2rem;
  }

  .hero-content > {
    min-width: 30%;
  }

  .left-column {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .right-column {
    flex: 1;
    display: flex;
    flex-direction: column;
    & > *:not(:last-child) {
      margin-bottom: 1rem;
    }
  }

  .row {
    flex: 1;
    background-position: left center;
    background-repeat: no-repeat;
    color: white;
    &.title {
      font-size: 1.3rem;
      font-weight: 600;
      min-width: max-content;
    }
    &.email, &.phone{
       padding-left: 30px;
    }
    &.social{
      display: flex;
      align-items: center;
      gap: .5rem;
      img {
        width: 1.4rem;
        height: auto;
      }
    }
  }

  @media (max-width: 800px) {
    .hero-content {
      flex-direction: column;
      gap: 3rem;
    }

    .right-column{
      display: flex;
      flex-direction: column;
      align-items: center;
    }
  }
</style>